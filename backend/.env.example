NODE_ENV=development
PORT=3001

# Firebase Admin SDK
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<paste key from firebase JSON as single line with \n>\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# URLs
NEXT_PUBLIC_B2B_URL=http://localhost:3000
BACKEND_PUBLIC_URL=https://your-backend-url.run.app
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Finik Payment (averspay.kg)
# All three values are provided by Finik after registration
FINIK_API_KEY=your-finik-api-key
FINIK_API_URL=https://api.**********.kg/payment
FINIK_ACCOUNT_ID=your-finik-account-id
# RSA private key (PKCS#1) — paste as single line with \n instead of newlines
# The corresponding public key (finik_public_key.pem) was sent to Finik during registration
FINIK_PRIVATE_PEM="-----BEGIN RSA PRIVATE KEY-----\n<paste private key as single line with \n>\n-----END RSA PRIVATE KEY-----\n"
